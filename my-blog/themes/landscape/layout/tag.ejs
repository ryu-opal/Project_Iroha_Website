<div class="layout-tag">
    <h1 class="LT-main-title">🏷️ 目前標籤：<span><%= page.tag %></span></h1>

    <!-- 2. 開始把文章寶寶們一張一張列出來 (迴圈魔法) -->
    <div class="LT-postlist">
        <% page.posts.each(function(post) { %>
            <!-- 這裡換成你想要的 tag-post-link 囉！ -->
            <a href="<%- url_for(post.path) %>" class="LT-postlink">
                <article>
                    <h2 class="LT-post-title"><%= post.title %></h2>
                    <span class="LT-post-date"><%= post.date.format('YYYY-MM-DD') %></span> 
                    <p class="LT-post-blurb"><%= strip_html(post.excerpt || post.content).substring(0, 100) + '...' %></p>
                </article>
            </a>
        <% }); %>
    </div>
</div>